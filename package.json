{
  "name": "fontext",
  "version": "1.11.0",
  "description": "Script for extracting glyphes by ligatures from font and creating new minimized fonts with them",
  "keywords": [
    "font",
    "ligatures",
    "minimizer",
    "assets",
    "svgFont",
    "ttf",
    "woff2",
    "woff",
    "eot",
    "convertor",
    "fontkit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a3mitskevich/fontext.git"
  },
  "homepage": "https://github.com/a3mitskevich/fontext",
  "author": "Aleksandr Mitskevich johndeathsmell@gmail.com",
  "license": "MIT",
  "bin": {
    "fontext": "dist/cli.js"
  },
  "files": [
    "dist/*"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:local": "TEST_TARGET=local npm run test",
    "test:dist": "TEST_TARGET=dist npm run test",
    "build": "tsup",
    "lint": "oxlint src/ test/ --tsconfig tsconfig.json --deny-warnings",
    "lint:fix": "oxlint src/ test/ --tsconfig tsconfig.json --fix",
    "format": "oxfmt --write src/ test/ *.ts",
    "format:check": "oxfmt --check src/ test/ *.ts",
    "cli:help": "node dist/cli.js --help",
    "cli:init": "node dist/cli.js --init",
    "prepare": "git config core.hooksPath .githooks && git config commit.template .gitmessage"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/fontkit": "^2.0.9",
    "@types/node": "^25.5.0",
    "@types/subset-font": "^2.3.0",
    "@types/svg2ttf": "^5.0.3",
    "@types/ttf2eot": "^2.0.2",
    "@types/ttf2woff": "^2.0.4",
    "@types/ttf2woff2": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "fontkit": "^2.0.4",
    "subset-font": "^2.4.0",
    "svg2ttf": "6.0.3",
    "svgicons2svgfont": "^16.0.0",
    "ttf2eot": "3.1.0",
    "ttf2woff": "3.0.0",
    "ttf2woff2": "^8.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
